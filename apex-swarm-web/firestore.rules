rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /run_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if false;
    }
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read: if false;
    }
  }
}
